---
layout: base.njk
title: Home
---

{# ───────────────── HERO ───────────────── #}
<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="hero-grain"></div>
    <div class="hero-gradient"></div>
  </div>
  <div class="hero-content">
    <p class="hero-eyebrow">Neuropsychology · Therapy · Assessment</p>
    <h1 class="hero-title">{{ site.tagline }}</h1>
    <p class="hero-subtitle">{{ site.heroSubtitle }}</p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-primary">Request an Appointment</a>
      <a href="#services" class="btn btn-ghost">Explore Services</a>
    </div>
  </div>
  <div class="hero-scroll-hint" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

{# ───────────────── ABOUT ───────────────── #}
<section class="about section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-image-col">
        <div class="about-image-frame">
          <div class="about-image-placeholder">
            <span class="placeholder-icon">✦</span>
            <span class="placeholder-text">Practice Photo</span>
          </div>
        </div>
        <div class="about-accent-shape" aria-hidden="true"></div>
      </div>
      <div class="about-text-col">
        {# <span class="section-label">About Us</span> #}
        <h2 class="section-title">{{ site.about.headline }}</h2>
        <p class="about-lead">{{ site.about.text }}</p>
        <p class="about-lead">{{ site.about.text2 }}</p>
        {# <blockquote class="about-philosophy"> #}
          {# <p>{{ site.about.philosophy }}</p> #}
        {# </blockquote> #}
        <a href="#provider" class="btn btn-outline">Meet Our Team</a>
      </div>
    </div>
  </div>
</section>

{# ───────────────── SERVICES ───────────────── #}
<section class="services section" id="services">
  <div class="container">
    <div class="section-header">
      <span class="section-label">What We Offer</span>
      <h2 class="section-title">Our Services</h2>
      <p class="section-subtitle">Every evaluation and session is tailored to your unique needs, guided by the latest research and a deep commitment to your well-being.</p>
    </div>

    <div class="services-grid">
      {% for service in site.services %}
      <article class="service-card" data-animate>
        <div class="service-icon">
          {% if service.icon == "brain" %}
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M24 4C16 4 10 10 10 18c0 5 2 9 6 12v10c0 2 2 4 4 4h8c2 0 4-2 4-4V30c4-3 6-7 6-12 0-8-6-14-14-14z"/><path d="M18 20c0-3 3-6 6-6"/><path d="M17 40h14"/><path d="M19 36h10"/></svg>
          {% elif service.icon == "focus" %}
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="18"/><circle cx="24" cy="24" r="12"/><circle cx="24" cy="24" r="6"/><circle cx="24" cy="24" r="2" fill="currentColor"/></svg>
          {% elif service.icon == "person" %}
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="14" r="8"/><path d="M8 42c0-9 7-16 16-16s16 7 16 16"/></svg>
          {% elif service.icon == "collaborate" %}
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="16" r="6"/><circle cx="32" cy="16" r="6"/><path d="M6 36c0-6 4-10 10-10h2"/><path d="M30 26h2c6 0 10 4 10 10"/><path d="M24 22v8"/><path d="M20 26h8"/></svg>
          {% endif %}
        </div>
        <h3 class="service-title">{{ service.title }}</h3>
        <p class="service-description">{{ service.description }}</p>
        <ul class="service-details">
          {% for detail in service.details %}
          <li>{{ detail }}</li>
          {% endfor %}
        </ul>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ───────────────── PROVIDER ───────────────── #}
<section class="provider section" id="provider">
  <div class="container">
    <div class="provider-grid">
      <div class="provider-text-col">
        <span class="section-label">Our Team</span>
        <h2 class="section-title">{{ site.provider.name }}</h2>
        <p class="provider-title-text">{{ site.provider.title }}</p>
        <p class="provider-bio">{{ site.provider.bio }}</p>
        <ul class="provider-credentials">
          {% for cred in site.provider.credentials %}
          <li>
            <span class="cred-bullet">✦</span>
            {{ cred }}
          </li>
          {% endfor %}
        </ul>
      </div>
      <div class="provider-image-col">
        <div class="provider-image-frame">
          <div class="provider-image-placeholder">
            <span class="placeholder-icon">✦</span>
            <span class="placeholder-text">Provider Headshot</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ───────────────── TESTIMONIALS ───────────────── #}
<section class="testimonials section" id="testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Kind Words</span>
      <h2 class="section-title">What Our Patients Say</h2>
    </div>
    <div class="testimonials-grid">
      {% for testimonial in site.testimonials %}
      <blockquote class="testimonial-card" data-animate>
        <div class="testimonial-quote-mark" aria-hidden="true">"</div>
        <p class="testimonial-text">{{ testimonial.quote }}</p>
        <cite class="testimonial-author">{{ testimonial.author }}</cite>
      </blockquote>
      {% endfor %}
    </div>
  </div>
</section>

{# ───────────────── INSURANCE ───────────────── #}
<section class="insurance section" id="insurance">
  <div class="container">
    <div class="insurance-grid">
      <div class="insurance-text">
        <span class="section-label">Coverage</span>
        <h2 class="section-title">{{ site.insurance.headline }}</h2>
        <p>{{ site.insurance.text }}</p>
      </div>
      <div class="insurance-providers">
        {% for provider in site.insurance.providers %}
        <div class="insurance-badge">{{ provider }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# ───────────────── FAQ ───────────────── #}
<section class="faq section" id="faq">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Common Questions</span>
      <h2 class="section-title">Frequently Asked Questions</h2>
    </div>
    <div class="faq-list">
      {% for item in site.faq %}
      <details class="faq-item">
        <summary class="faq-question">
          <span>{{ item.question }}</span>
          <span class="faq-toggle" aria-hidden="true">+</span>
        </summary>
        <div class="faq-answer">
          <p>{{ item.answer }}</p>
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

{# ───────────────── CONTACT ───────────────── #}
<section class="contact section" id="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Get in Touch</span>
      <h2 class="section-title">We'd Love to Hear from You</h2>
      <p class="section-subtitle">Ready to take the next step? Reach out to schedule an appointment or ask a question. We're here to help.</p>
    </div>

    <div class="contact-actions">
      <a href="tel:{{ site.phone | replace('(', '') | replace(')', '') | replace(' ', '') | replace('-', '') }}" class="contact-action-card">
        <span class="contact-action-label">Call Us</span>
        <span class="contact-action-value">{{ site.phone }}</span>
      </a>
      <a href="mailto:{{ site.email }}" class="contact-action-card">
        <span class="contact-action-label">Email Us</span>
        <span class="contact-action-value">{{ site.email }}</span>
      </a>
    </div>

    <div class="contact-details">
      <div class="contact-detail">
        <span class="contact-detail-label">Address</span>
        <p>{{ site.address.street }}<br>{{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}</p>
      </div>
      <div class="contact-detail">
        <span class="contact-detail-label">Hours</span>
        <p>{{ site.hours }}</p>
      </div>
    </div>
  </div>
</section>
